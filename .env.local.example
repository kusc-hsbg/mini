# --- Supabase ---
# Supabase 프로젝트 > Settings > API 에서 복사하세요.
# 미설정 시 앱은 자동으로 싱글플레이 데모 모드로 동작합니다.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# 배포 후 OAuth 리다이렉트에 사용할 사이트 URL (예: https://your-app.vercel.app)
# 로컬에서는 비워두면 자동으로 http://localhost:3000 을 사용합니다.
NEXT_PUBLIC_SITE_URL=
